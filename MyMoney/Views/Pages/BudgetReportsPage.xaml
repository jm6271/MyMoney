<Page
    x:Class="MyMoney.Views.Pages.BudgetReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MyMoney.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MyMoney.Views.Pages"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="BudgetReportsPage"
    d:DataContext="{d:DesignInstance {x:Type local:BudgetReportsPage},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="Col0" Width="200" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" x:Name="Row0"/>
            <RowDefinition Height="0" x:Name="Row1"/>
        </Grid.RowDefinitions>

        <ui:Card
            x:Name="BudgetsCard"
            Grid.Column="0"
            Margin="0,0,8,24"
            VerticalAlignment="Stretch"
            VerticalContentAlignment="Stretch">
            <ui:ListView
                x:Name="BudgetsListView"
                VerticalAlignment="Stretch"
                ItemsSource="{Binding ViewModel.Budgets}"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                SelectedIndex="{Binding ViewModel.SelectedBudgetIndex}"
                SelectedItem="{Binding ViewModel.SelectedBudget, Mode=TwoWay}">
                <ui:ListView.ItemTemplate>
                    <DataTemplate>
                        <ui:TextBlock Margin="5" Text="{Binding BudgetTitle}" />
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>
        </ui:Card>

        <ScrollViewer
            Grid.Column="1"
            Margin="0,0,-42,0"
            VerticalScrollBarVisibility="Auto"
            PanningMode="VerticalOnly"
            PanningRatio="1.5"
            PanningDeceleration="0.001"
            PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <Grid Margin="0,0,42,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" x:Name="ChartColumn1"/>
                    <ColumnDefinition Width="*" x:Name="ChartColumn2"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="400" />
                </Grid.RowDefinitions>

                <Controls:BudgetReportControl
                    x:Name="BudgetReport"
                    Title="{Binding ViewModel.ReportTitle}"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="8,0,0,8"
                    ExpenseItems="{Binding ViewModel.ExpenseItems}"
                    IncomeItems="{Binding ViewModel.IncomeItems}"
                    ReportTotal="{Binding ViewModel.ReportTotal}"
                    SavingsItems="{Binding ViewModel.SavingsItems}" />

                <ui:Card
                    x:Name="IncomeChart"
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="8,8,8,24"
                    VerticalAlignment="Top"
                    VerticalContentAlignment="Stretch">
                    <StackPanel>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            FontSize="25">
                            Actual Income
                        </TextBlock>
                        <lvc:PieChart
                            Height="300"
                            Background="Transparent"
                            Series="{Binding ViewModel.ActualIncomeSeries}" />
                    </StackPanel>
                </ui:Card>

                <ui:Card
                    x:Name="ExpenseChart"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="8,8,0,24"
                    VerticalAlignment="Top"
                    VerticalContentAlignment="Stretch">
                    <StackPanel>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            FontSize="25">
                            Actual Expenses
                        </TextBlock>
                        <lvc:PieChart
                            Height="300"
                            Background="Transparent"
                            Series="{Binding ViewModel.ActualExpenseSeries}" />
                    </StackPanel>
                </ui:Card>
            </Grid>
        </ScrollViewer>


    </Grid>
</Page>
