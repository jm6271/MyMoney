<Page
    x:Class="MyMoney.Views.Pages.BudgetReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MyMoney.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MyMoney.Views.Pages"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="BudgetReportsPage"
    d:DataContext="{d:DesignInstance {x:Type local:BudgetReportsPage},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="Row0" Height="Auto" />
            <RowDefinition x:Name="Row1" Height="*" />
        </Grid.RowDefinitions>
        <Grid Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,0,0,16">
                <ui:Button Command="{Binding ViewModel.PreviousReportMonthCommand}">
                    <ui:SymbolIcon FontSize="20" Symbol="ArrowLeft24" />
                </ui:Button>

                <controls:MonthPicker
                    Margin="12,0,12,0"
                    VerticalAlignment="Center"
                    AccentColor="{DynamicResource AccentFillColorSecondaryBrush}"
                    PopupMaxWidth="600"
                    SelectedMonth="{Binding ViewModel.SelectedReportMonth}"
                    SelectionChangedCommand="{Binding ViewModel.ReportMonthChangedCommand}"
                    TileHeight="75"
                    TileWidth="100" />

                <ui:Button Command="{Binding ViewModel.NextReportMonthCommand}">
                    <ui:SymbolIcon FontSize="20" Symbol="ArrowRight24" />
                </ui:Button>
            </StackPanel>

            <Separator Grid.Row="1"/>
        </Grid>

        <ScrollViewer
            Grid.Row="1"
            Margin="0,0,-42,0"
            PanningDeceleration="0.001"
            PanningMode="VerticalOnly"
            PanningRatio="1.5"
            PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
            VerticalScrollBarVisibility="Auto">
            <Grid Margin="12,0,54,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ChartColumn1" Width="*" />
                    <ColumnDefinition x:Name="ChartColumn2" Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="400" />
                </Grid.RowDefinitions>

                <controls:BudgetReportControl
                    x:Name="BudgetReport"
                    Title="{Binding ViewModel.ReportTitle}"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,8"
                    ExpenseItems="{Binding ViewModel.ExpenseItems}"
                    IncomeItems="{Binding ViewModel.IncomeItems}"
                    ReportTotal="{Binding ViewModel.ReportTotal}"
                    SavingsItems="{Binding ViewModel.SavingsItems}" />

                <ui:Card
                    x:Name="IncomeChart"
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,8,8,24"
                    VerticalAlignment="Top"
                    VerticalContentAlignment="Stretch">
                    <StackPanel>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            FontSize="25">
                            Actual Income
                        </TextBlock>
                        <lvc:PieChart
                            Height="300"
                            Background="Transparent"
                            Series="{Binding ViewModel.ActualIncomeSeries}" />
                    </StackPanel>
                </ui:Card>

                <ui:Card
                    x:Name="ExpenseChart"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="8,8,0,24"
                    VerticalAlignment="Top"
                    VerticalContentAlignment="Stretch">
                    <StackPanel>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            FontSize="25">
                            Actual Expenses
                        </TextBlock>
                        <lvc:PieChart
                            Height="300"
                            Background="Transparent"
                            Series="{Binding ViewModel.ActualExpenseSeries}" />
                    </StackPanel>
                </ui:Card>
            </Grid>
        </ScrollViewer>


    </Grid>
</Page>
