<Page
    x:Class="MyMoney.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MyMoney.Views.Controls"
    xmlns:converters="clr-namespace:MyMoney.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MyMoney.Views.Pages"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:MyMoney.Core.Models;assembly=MyMoney.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="DashboardPage"
    d:DataContext="{d:DesignInstance {x:Type local:DashboardPage},
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="900"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    SizeChanged="Page_SizeChanged"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:IsLastItemConverter x:Key="IsLastItemConverter" />
        <converters:DoubleToUpDownIconConverter x:Key="DoubleToUpDownIconConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="200" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Border
            Grid.Row="0"
            VerticalAlignment="Stretch"
            CornerRadius="8">
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Assets/MyMoney-Banner.png" Stretch="Fill" />
            </Border.Background>
            <StackPanel Margin="24,0,0,0" VerticalAlignment="Center">
                <StackPanel.Resources>
                    <DropShadowEffect
                        x:Key="TextBlockShadowEffect"
                        BlurRadius="4"
                        Direction="330"
                        Opacity="0.5"
                        ShadowDepth="4"
                        Color="Black" />
                </StackPanel.Resources>
                <ui:TextBlock
                    Effect="{StaticResource TextBlockShadowEffect}"
                    FontTypography="TitleLarge"
                    Foreground="LightGray"
                    Text="MyMoney" />
                <ui:TextBlock
                    Effect="{StaticResource TextBlockShadowEffect}"
                    FontTypography="Title"
                    Foreground="LightGray"
                    Text="Personal Finance Software" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="Col0" Width="4*" />
                <ColumnDefinition x:Name="Col1" Width="3*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition x:Name="Row0" Height="Auto" />
                <RowDefinition x:Name="Row1" Height="1*" />
                <RowDefinition x:Name="Row2" Height="Auto" />
            </Grid.RowDefinitions>

            <Grid
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <!--  Quick overview cards  -->
                <ui:Card
                    Height="160"
                    Margin="0,0,12,0"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <!--  Net Worth  -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="18">Net Worth</TextBlock>
                        <lvc:CartesianChart
                            Grid.Row="1"
                            Margin="0,8,0,8"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            Series="{Binding ViewModel.NetWorthSeries}"
                            TooltipPosition="Hidden"
                            XAxes="{Binding ViewModel.NetWorthXAxes}"
                            YAxes="{Binding ViewModel.NetWorthYAxes}" />
                        <Viewbox Grid.Row="2" MaxHeight="40">
                            <TextBlock FontWeight="SemiBold" Text="{Binding ViewModel.TotalNetWorth}" />
                        </Viewbox>
                    </Grid>
                </ui:Card>

                <ui:Card
                    Grid.Column="1"
                    Height="160"
                    Margin="4,0,8,0"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <!--  Cash Flow  -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="18">Cash Flow</TextBlock>
                        <Viewbox
                            Grid.Row="1"
                            Margin="0,8,0,8"
                            HorizontalAlignment="Left">
                            <TextBlock Foreground="{Binding ViewModel.CashFlowTotalColorBrush}" Text="{Binding ViewModel.CashFlowTotalFormatted}" />
                        </Viewbox>
                        <WrapPanel Grid.Row="2">
                            <ui:SymbolIcon
                                VerticalAlignment="Center"
                                Filled="True"
                                Foreground="{Binding ViewModel.CashFlowPercentageColorBrush}"
                                Symbol="{Binding ViewModel.CashFlowPercentVsLastMonth, Converter={StaticResource DoubleToUpDownIconConverter}}" />
                            <TextBlock Text=" " />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{Binding ViewModel.CashFlowPercentageColorBrush}"
                                Text="{Binding ViewModel.CashFlowPercentVsLastMonth}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{Binding ViewModel.CashFlowPercentageColorBrush}"
                                Text="%" />
                            <TextBlock VerticalAlignment="Center" Text="  vs last month" />
                        </WrapPanel>
                    </Grid>
                </ui:Card>

                <ui:Card
                    Grid.Column="2"
                    Height="160"
                    Margin="8,0,4,0"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <!--  Budget health  -->
                    <StackPanel>
                        <TextBlock FontSize="18">Budget</TextBlock>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ui:SymbolIcon
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                FontSize="24"
                                Foreground="{Binding ViewModel.BudgetHealthIconColorBrush}"
                                Symbol="{Binding ViewModel.BudgetHealthIcon}" />

                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{Binding ViewModel.BudgetHealthText}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:Card
                    Grid.Column="3"
                    Height="160"
                    Margin="12,0,0,0"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
                    <!--  Spending vs. last month  -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="18">Spending</TextBlock>

                        <Viewbox
                            Grid.Row="1"
                            Margin="0,8,0,8"
                            HorizontalAlignment="Left">
                            <TextBlock Text="{Binding ViewModel.TotalSpending}" />
                        </Viewbox>

                        <WrapPanel Grid.Row="2">
                            <ui:SymbolIcon
                                VerticalAlignment="Center"
                                Filled="True"
                                Foreground="{Binding ViewModel.SpendingPercentageColorBrush}"
                                Symbol="{Binding ViewModel.SpendingVsLastMonthPercentage, Converter={StaticResource DoubleToUpDownIconConverter}}" />
                            <TextBlock Text=" " />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{Binding ViewModel.SpendingPercentageColorBrush}"
                                Text="{Binding ViewModel.SpendingVsLastMonthPercentage}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{Binding ViewModel.SpendingPercentageColorBrush}"
                                Text="%" />
                            <TextBlock VerticalAlignment="Center" Text="  vs last month" />
                        </WrapPanel>
                    </Grid>
                </ui:Card>
            </Grid>

            <ui:Card
                x:Name="budgetOverviewPanel"
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,8,8,24"
                VerticalAlignment="Top">
                <StackPanel Grid.IsSharedSizeScope="True">
                    <ui:TextBlock Margin="0,0,0,24" FontTypography="Subtitle">Budget Overview</ui:TextBlock>
                    <Grid Margin="16,0,16,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Sep1" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Budgeted" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Sep2" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Actual" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Sep3" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="Remaining" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            FontWeight="SemiBold"
                            Text="Category" />
                        <Separator Grid.Column="1" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="8,0,8,0"
                            FontWeight="SemiBold"
                            Text="Budgeted"
                            TextAlignment="Right" />
                        <Separator Grid.Column="3" />
                        <TextBlock
                            Grid.Column="4"
                            Margin="8,0"
                            FontWeight="SemiBold"
                            Text="Actual"
                            TextAlignment="Right" />
                        <Separator Grid.Column="5" />
                        <TextBlock
                            Grid.Column="6"
                            Margin="8,0,0,0"
                            FontWeight="SemiBold"
                            Text="Remaining"
                            TextAlignment="Right" />
                    </Grid>

                    <Separator />

                    <ItemsControl ItemsSource="{Binding ViewAdapter.GroupedBudgetReportItemsView}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Controls:BudgetSummaryItem
                                    Margin="0,2"
                                    ActualAmount="{Binding Actual}"
                                    BudgetedAmount="{Binding Budgeted}"
                                    Category="{Binding Category}"
                                    IsExpense="{Binding IsExpense}"
                                    RemainingAmount="{Binding Remaining}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <ui:TextBlock
                                            Margin="0,10,0,6"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource AccentTextFillColorTertiaryBrush}"
                                            Text="{Binding Name}" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                    </ItemsControl>
                </StackPanel>
            </ui:Card>

            <StackPanel
                x:Name="RightPanel"
                Grid.Row="1"
                Grid.Column="1"
                Margin="8,8,0,0">
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <ui:TextBlock Margin="0,0,0,16" FontTypography="Subtitle">
                            <Run Text="Accounts" />
                        </ui:TextBlock>
                        <ui:ListView x:Name="AccountsListView" ItemsSource="{Binding ViewModel.Accounts}">
                            <ui:ListView.Resources>
                                <Style x:Key="LastItemTextBlockStyle" TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource IsLastItemConverter}">
                                                    <!--  current item  -->
                                                    <Binding />
                                                    <!--  the ItemsSource on the nearest ListView  -->
                                                    <Binding ElementName="AccountsListView" Path="ItemsSource" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter Property="FontWeight" Value="Bold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:ListView.Resources>
                            <ui:ListView.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:AccountDashboardDisplayItem}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="5,5,0,5"
                                            Style="{StaticResource LastItemTextBlockStyle}"
                                            Text="{Binding AccountName}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="0,5,5,5"
                                            Style="{StaticResource LastItemTextBlockStyle}"
                                            Text="{Binding Total}" />
                                    </Grid>
                                </DataTemplate>
                            </ui:ListView.ItemTemplate>
                        </ui:ListView>
                    </StackPanel>
                </ui:Card>
                <ui:Card Margin="0,8,0,8">
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center" FontSize="25">Income vs. Expenses</TextBlock>
                        <lvc:CartesianChart
                            x:Name="IncomeExpenseChart"
                            Height="350"
                            Background="Transparent"
                            XAxes="{Binding ViewModel.XAxes}"
                            YAxes="{Binding ViewModel.YAxes}">
                            <lvc:CartesianChart.Series>
                                <lvc:SeriesCollection>
                                    <lvc:XamlColumnSeries PointMeasuredCommand="{Binding ViewModel.IncomeExpenseOnPointMeasuredCommand}" Values="{Binding ViewModel.IncomeExpenseSeries}" />
                                </lvc:SeriesCollection>
                            </lvc:CartesianChart.Series>
                        </lvc:CartesianChart>
                    </StackPanel>

                </ui:Card>

                <ui:Card
                    x:Name="ExpenseChart"
                    Grid.Row="1"
                    Margin="0,8,0,24"
                    VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="400" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="25"
                            Text="Expenses by Category" />

                        <lvc:PieChart
                            Grid.Row="1"
                            Background="Transparent"
                            LegendPosition="Bottom"
                            LegendTextPaint="{Binding ViewModel.ExpenseBreakdownForeColor}"
                            Series="{Binding ViewModel.ExpensePercentagesSeries}" />
                    </Grid>
                </ui:Card>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
