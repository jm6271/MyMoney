<Page
    x:Class="MyMoney.Views.Pages.BudgetPage"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:MyMoney.Views.Pages"
    xmlns:dataannotations="clr-namespace:System.ComponentModel.DataAnnotations;assembly=System.ComponentModel.DataAnnotations"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:converters="clr-namespace:MyMoney.Converters"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:controls="clr-namespace:MyMoney.Views.Controls"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800"
    d:DataContext="{d:DesignInstance local:BudgetPage,
                                 IsDesignTimeCreatable=False}"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    xmlns:models="clr-namespace:MyMoney.Core.Models;assembly=MyMoney.Core"
>
    <Page.Resources>
        <ResourceDictionary>
            <converters:LeftToBudgetTextConverter x:Key="LeftToBudgetTextConverter" />
            <converters:CurrencyAbsoluteValueConverter x:Key="CurrencyAbsoluteValueConverter" />
            <converters:NegativeCurrencyToRedColorConverter x:Key="NegativeCurrencyToRedColorConverter" />
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:BooleanToInverseVisibilityConverter x:Key="BooleanToInverseVisibilityConverter"/>
            <converters:IntToMonthNameConverter x:Key="IntToMonthNameConverter"/>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="Col1" Width="*" />
            <ColumnDefinition x:Name="Col2" Width="250" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition x:Name="Row0" Height="*" />
            <RowDefinition x:Name="Row1" Height="0" />
            <RowDefinition x:Name="Row2" Height="0" />
        </Grid.RowDefinitions>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:MonthPicker HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                      SelectedMonth="{Binding ViewModel.SelectedBudgetMonth}"
                                      SelectionChangedCommand="{Binding ViewModel.BudgetMonthChangedCommand}"
                                      AccentColor="{DynamicResource AccentFillColorSecondaryBrush}"
                                      PopupMaxWidth="750" TileWidth="100" TileHeight="75"/>

                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                    <ui:Button Command="{Binding ViewModel.PreviousBudgetMonthCommand}">
                        <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="20"/>
                    </ui:Button>
                    <ui:Button Command="{Binding ViewModel.NextBudgetMonthCommand}">
                        <ui:SymbolIcon Symbol="ArrowRight24" FontSize="20"/>
                    </ui:Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,4,0,0" 
                            Visibility="{Binding ViewModel.IsEditingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding ViewModel.LeftToBudget, Converter={StaticResource CurrencyAbsoluteValueConverter}}"
                                   Foreground="{Binding ViewModel.LeftToBudget, Converter={StaticResource NegativeCurrencyToRedColorConverter}}"
                        />
                    <TextBlock VerticalAlignment="Center"
                                   Text="{Binding ViewModel.LeftToBudget, Converter={StaticResource LeftToBudgetTextConverter}}"
                        />
                </StackPanel>
            </Grid>

            <Separator Grid.Row="1" Margin="0,0,12,0"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="2" 
                          Margin="24,0,36,0" PanningMode="VerticalOnly"
                          PanningRatio="1.5"
                          PanningDeceleration="0.001"
                          x:Name="MainScrollViewer"
                          PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel"
                          Visibility="{Binding ViewModel.IsEditingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel x:Name="BudgetPanel" Margin="0,12,12,16">

                    <ui:CardExpander IsExpanded="True" Margin="0,8,0,8">
                        <ui:CardExpander.Header>
                            <ui:TextBlock FontTypography="Subtitle">Income</ui:TextBlock>
                        </ui:CardExpander.Header>

                        <StackPanel>
                            <ui:ListView
                                ItemsSource="{Binding ViewModel.CurrentBudget.BudgetIncomeItems}"
                                SelectedIndex="{Binding ViewModel.IncomeItemsSelectedIndex}"
                                SizeChanged="ListView_SizeChanged"
                                SelectionMode="Single"
                                dd:DragDrop.IsDragSource="True"
                                dd:DragDrop.IsDropTarget="True"
                                dd:DragDrop.DropHandler="{Binding ViewModel.IncomeItemsReorderHandler}"
                                dd:DragDrop.DragHandler="{Binding ViewModel.IncomeItemsReorderHandler}"
                                Margin="0,0,0,8"
                            >
                                <ui:ListView.Resources>
                                    <DataTemplate x:Key="CategoryItemTemplate">
                                        <ui:TextBlock Text="{Binding Category}" Margin="0,5,0,5" />
                                    </DataTemplate>
                                    <DataTemplate x:Key="BudgetedItemTemplate">
                                        <ui:TextBlock Text="{Binding Amount}" Margin="0,5,0,5" />
                                    </DataTemplate>
                                    <DataTemplate x:Key="ActualItemTemplate">
                                        <ui:TextBlock Text="{Binding Actual}" Margin="0,5,5,5" />
                                    </DataTemplate>
                                </ui:ListView.Resources>

                                <ui:ListView.ContextMenu>
                                    <ContextMenu IsEnabled="{Binding ViewModel.IsEditingEnabled}">
                                        <MenuItem Header="Edit" Command="{Binding ViewModel.EditIncomeItemCommand}" />
                                        <MenuItem Header="Delete" Command="{Binding ViewModel.DeleteIncomeItemCommand}" />
                                    </ContextMenu>
                                </ui:ListView.ContextMenu>

                                <ui:ListView.InputBindings>
                                    <KeyBinding Key="Delete" Command="{Binding ViewModel.DeleteIncomeItemCommand}" />
                                </ui:ListView.InputBindings>

                                <ui:ListView.View>
                                    <ui:GridView>
                                        <ui:GridViewColumn Header="Category" CellTemplate="{StaticResource CategoryItemTemplate}" />
                                        <ui:GridViewColumn
                                    Header="Budgeted"
                                    CellTemplate="{StaticResource BudgetedItemTemplate}"
                                    Width="125"
                                />
                                        <ui:GridViewColumn
                                    Header="Actual"
                                    CellTemplate="{StaticResource ActualItemTemplate}"
                                    Width="125"
                                />
                                    </ui:GridView>
                                </ui:ListView.View>
                            </ui:ListView>

                            <ui:Button Command="{Binding ViewModel.AddIncomeItemCommand}"
                                       IsEnabled="{Binding ViewModel.IsEditingEnabled}"
                                       Content="Add Income"/>
                        </StackPanel>


                    </ui:CardExpander>

                    <ui:CardExpander Margin="0,8,0,8" IsExpanded="True">
                        <ui:CardExpander.Header>
                            <ui:TextBlock FontTypography="Subtitle">Savings</ui:TextBlock>
                        </ui:CardExpander.Header>

                        <StackPanel>
                            <ui:ListView
                                ItemsSource="{Binding ViewModel.CurrentBudget.BudgetSavingsCategories}"
                                SelectedIndex="{Binding ViewModel.SavingsCategoriesSelectedIndex}"
                                SizeChanged="ListView_SizeChanged"
                                SelectionMode="Single"
                                Margin="0,0,0,8"
                                dd:DragDrop.IsDragSource="True"
                                dd:DragDrop.IsDropTarget="True"
                                dd:DragDrop.DropHandler="{Binding ViewModel.SavingsCategoryReorderHandler}"
                                dd:DragDrop.DragHandler="{Binding ViewModel.SavingsCategoryReorderHandler}"
                            >
                                <ui:ListView.Resources>
                                    <DataTemplate x:Key="CategoryItemTemplate">
                                        <ui:TextBlock Text="{Binding CategoryName}" Margin="0,5,0,5" />
                                    </DataTemplate>
                                    <DataTemplate x:Key="BudgetedItemTemplate">
                                        <ui:TextBlock Text="{Binding BudgetedAmount}" Margin="0,5,0,5" />
                                    </DataTemplate>
                                    <DataTemplate x:Key="ActualItemTemplate">
                                        <ui:TextBlock Text="{Binding CurrentBalance}" Margin="0,5,5,5" />
                                    </DataTemplate>
                                </ui:ListView.Resources>

                                <ui:ListView.ContextMenu>
                                    <ContextMenu IsEnabled="{Binding ViewModel.IsEditingEnabled}">
                                        <MenuItem Header="Edit" Command="{Binding ViewModel.EditSavingsCategoryCommand}" />
                                        <MenuItem Header="Delete" Command="{Binding ViewModel.DeleteSavingsCategoryCommand}" />
                                    </ContextMenu>
                                </ui:ListView.ContextMenu>

                                <ui:ListView.InputBindings>
                                    <KeyBinding Key="Delete" Command="{Binding ViewModel.DeleteSavingsCategoryCommand}" />
                                </ui:ListView.InputBindings>

                                <ui:ListView.View>
                                    <ui:GridView>
                                        <ui:GridViewColumn Header="Category" CellTemplate="{StaticResource CategoryItemTemplate}" />
                                        <ui:GridViewColumn
                                            Header="Saved"
                                            CellTemplate="{StaticResource BudgetedItemTemplate}"
                                            Width="125"
                                        />
                                        <ui:GridViewColumn
                                            Header="Balance"
                                            CellTemplate="{StaticResource ActualItemTemplate}"
                                            Width="125"
                                        />
                                    </ui:GridView>
                                </ui:ListView.View>
                            </ui:ListView>

                            <ui:Button Content="Add Item" IsEnabled="{Binding ViewModel.IsEditingEnabled}"
                                       Command="{Binding ViewModel.AddSavingsCategoryCommand}"/>
                        </StackPanel>
                    </ui:CardExpander>

                    <ItemsControl
                x:Name="ExpensesItemsControl"
                ItemsSource="{Binding ViewModel.CurrentBudget.BudgetExpenseItems}"
                dd:DragDrop.IsDragSource="True"
                dd:DragDrop.IsDropTarget="True"
                dd:DragDrop.DropHandler="{Binding ViewModel.ExpenseGroupsReorderHandler}"
                dd:DragDrop.DragHandler="{Binding ViewModel.ExpenseGroupsReorderHandler}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:CardExpander
                            Margin="0,8,0,8"
                            Expanded="CardExpander_Expanded"
                            Collapsed="CardExpander_Expanded"
                            IsExpanded="{Binding IsExpanded, UpdateSourceTrigger=PropertyChanged}"
                            >
                                    <ui:CardExpander.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBlock
                                        FontTypography="Subtitle"
                                        Text="{Binding CategoryName}"
                                        Margin="0,0,24,0"
                                    />
                                            <ui:Button
                                        Margin="0,0,4,0"
                                        Grid.Column="1"
                                        Command="{Binding DataContext.ViewModel.EditExpenseGroupCommand, 
                                                    RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                        CommandParameter="{Binding}"
                                    >
                                                <ui:SymbolIcon Symbol="Edit24" />
                                                <ui:Button.ToolTip>
                                                    <ToolTip Content="Edit group" />
                                                </ui:Button.ToolTip>
                                            </ui:Button>
                                            <ui:Button
                                        Margin="4,0,24,0"
                                        Grid.Column="2"
                                        Command="{Binding DataContext.ViewModel.DeleteExpenseGroupCommand,
                                                    RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                        CommandParameter="{Binding}"
                                    >
                                                <ui:SymbolIcon Symbol="Delete24" />
                                                <ui:Button.ToolTip>
                                                    <ToolTip Content="Delete group" />
                                                </ui:Button.ToolTip>
                                            </ui:Button>
                                        </Grid>
                                    </ui:CardExpander.Header>
                                    <StackPanel>
                                        <ui:ListView
                                    ItemsSource="{Binding SubItems}"
                                    SelectedIndex="{Binding SelectedSubItemIndex}"
                                    Tag="{Binding DataContext.ViewModel, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                    SelectionMode="Single"
                                    MinHeight="50"
                                    Margin="0,0,0,8"
                                    SizeChanged="ListView_SizeChanged"
                                    dd:DragDrop.IsDragSource="True"
                                    dd:DragDrop.IsDropTarget="True"
                                    dd:DragDrop.DropHandler="{Binding DataContext.ViewModel.ExpenseItemsMoveAndReorderHandler,
                                                                        RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                    dd:DragDrop.DragHandler="{Binding DataContext.ViewModel.ExpenseItemsMoveAndReorderHandler,
                                                                        RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                >
                                            <ui:ListView.Resources>
                                                <DataTemplate x:Key="CategoryItemTemplate">
                                                    <ui:TextBlock Text="{Binding Category}" Margin="0,5,0,5" />
                                                </DataTemplate>
                                                <DataTemplate x:Key="BudgetedItemTemplate">
                                                    <ui:TextBlock Text="{Binding Amount}" Margin="0,5,0,5" />
                                                </DataTemplate>
                                                <DataTemplate x:Key="ActualItemTemplate">
                                                    <ui:TextBlock Text="{Binding Actual}" Margin="0,5,5,5" />
                                                </DataTemplate>
                                            </ui:ListView.Resources>
                                            <ui:ListView.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem
                                                Header="Edit"
                                                Command="{Binding PlacementTarget.Tag.EditExpenseItemCommand,
                                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                CommandParameter="{Binding}"
                                            />
                                                    <MenuItem
                                                Header="Delete"
                                                Command="{Binding PlacementTarget.Tag.DeleteExpenseItemCommand,
                                                                            RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                CommandParameter="{Binding}"
                                            />
                                                </ContextMenu>
                                            </ui:ListView.ContextMenu>

                                            <ui:ListView.View>
                                                <ui:GridView>
                                                    <ui:GridViewColumn
                                                Header="Category"
                                                CellTemplate="{StaticResource CategoryItemTemplate}"
                                            />
                                                    <ui:GridViewColumn
                                                Header="Budgeted"
                                                CellTemplate="{StaticResource BudgetedItemTemplate}"
                                                Width="125"
                                            />
                                                    <ui:GridViewColumn
                                                Header="Actual"
                                                CellTemplate="{StaticResource ActualItemTemplate}"
                                                Width="125"
                                            />
                                                </ui:GridView>
                                            </ui:ListView.View>
                                        </ui:ListView>

                                        <ui:Button
                                    Command="{Binding DataContext.ViewModel.AddExpenseItemCommand, 
                                                    RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                    CommandParameter="{Binding}"
                                    Content="Add Item"
                                />
                                    </StackPanel>
                                </ui:CardExpander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button HorizontalAlignment="Stretch" Height="75" Margin="0,8,0,8"
                            Background="Transparent" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="2" HorizontalContentAlignment="Stretch"
                            Command="{Binding ViewModel.AddExpenseGroupCommand}"
                            IsEnabled="{Binding ViewModel.IsEditingEnabled}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:SymbolIcon Symbol="Add24" Margin="0,0,8,0" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Add Group" Grid.Column="1" FontSize="16" FontWeight="SemiBold"/>
                        </Grid>
                    </Button>

                    <ui:Button Margin="0,24,0,8" Command="{Binding ViewModel.DeleteBudgetCommand}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Delete24"/>
                            <TextBlock Margin="8,0,0,0">Delete Budget</TextBlock>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" VerticalAlignment="Center"
                        Visibility="{Binding ViewModel.IsEditingEnabled, Converter={StaticResource BooleanToInverseVisibilityConverter}}">
                <ui:Button Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="24" Appearance="Primary" Command="{Binding ViewModel.CreateNewBudgetCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Symbol="FormNew24" Margin="0,0,8,0"/>
                        <ui:TextBlock Grid.Column="1" VerticalAlignment="Center" Text="Create a Budget for "/>
                        <ui:TextBlock Grid.Column="2" 
                                      Text="{Binding ViewModel.SelectedBudgetMonth.Month, Converter={StaticResource IntToMonthNameConverter}}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </ui:Button>

                <ui:TextBlock Margin="0,16,0,0" HorizontalAlignment="Center" Text="{Binding ViewModel.NewBudgetCopyInfo}"/>
            </StackPanel>

        </Grid>

        <ScrollViewer Grid.Column="1" Margin="0,0,-42,0"
                      PanningMode="VerticalOnly"
                      PanningRatio="1.5"
                      PanningDeceleration="0.001"
                      Visibility="{Binding ViewModel.IsEditingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Grid.Column="1" Margin="0,0,42,24" x:Name="ChartsPanel">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="ChartRow0" Height="Auto" />
                    <RowDefinition x:Name="ChartRow1" Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ChartCol0" Width="*" />
                    <ColumnDefinition x:Name="ChartCol1" Width="0" />
                </Grid.ColumnDefinitions>

                <ui:Card
                    Margin="0,0,0,8"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Grid.Row="0"
                    x:Name="IncomeChart"
                >
                    <StackPanel>
                        <TextBlock Text="Income" FontSize="25" HorizontalAlignment="Center" />
                        <Grid>
                            <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform">
                                <TextBlock Text="{Binding ViewModel.IncomeTotal}" Margin="42" />
                            </Viewbox>

                            <lvc:PieChart Series="{Binding ViewModel.IncomePercentagesSeries}" Height="275" 
                                          Background="Transparent"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:Card
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Margin="0,8,0,0"
                    Grid.Row="1"
                    x:Name="ExpenseChart"
                >
                    <StackPanel>
                        <TextBlock Text="Expenses" FontSize="25" HorizontalAlignment="Center" />
                        <Grid>
                            <Viewbox HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform">
                                <TextBlock Text="{Binding ViewModel.ExpenseTotal}" Margin="42" />
                            </Viewbox>

                            <lvc:PieChart Series="{Binding ViewModel.ExpensePercentagesSeries}" Height="275" 
                                          Background="Transparent"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </ScrollViewer>
        
    </Grid>
</Page>
