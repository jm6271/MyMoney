<Page
    x:Class="MyMoney.Views.Pages.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MyMoney.Views.Pages"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:MyMoney.Core.Models;assembly=MyMoney.Core"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Reports"
    d:DataContext="{d:DesignInstance local:ReportsPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <ui:Card Margin="0,0,0,16">
            <lvc:CartesianChart
                Grid.Row="0"
                Height="400"
                Background="Transparent"
                LegendPosition="Bottom"
                LegendTextPaint="{Binding ViewModel.IncomeExpense12MonthLegendPaint}"
                Series="{Binding ViewModel.IncomeExpense12MonthSeries}"
                XAxes="{Binding ViewModel.IncomeExpense12MonthXAxes}"
                YAxes="{Binding ViewModel.IncomeExpense12MonthYAxes}" />
        </ui:Card>

        <ui:Card Grid.Row="1" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="250" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,8">
                    <ui:TextBlock Margin="0,0,0,8" FontTypography="Subtitle">Net Worth</ui:TextBlock>
                    <ui:TextBlock FontTypography="Title" Text="{Binding ViewModel.TotalNetWorth}" />
                </StackPanel>

                <ComboBox
                    Grid.Column="1"
                    Width="150"
                    VerticalAlignment="Top"
                    SelectedIndex="{Binding ViewModel.NetWorthPeriodIndex}">
                    <ComboBoxItem Content="7 Days" />
                    <ComboBoxItem Content="Week to Date" />
                    <ComboBoxItem Content="30 Days" />
                    <ComboBoxItem Content="Month to Date" />
                    <ComboBoxItem Content="90 Days" />
                    <ComboBoxItem Content="365 Days" />
                    <ComboBoxItem Content="Year to Date" />
                </ComboBox>

                <lvc:CartesianChart
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    Series="{Binding ViewModel.NetWorthSeries}"
                    XAxes="{Binding ViewModel.NetWorthXAxes}"
                    YAxes="{Binding ViewModel.NetWorthYAxes}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    Text="{Binding ViewModel.NetWorthStartDate}" />
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Text="{Binding ViewModel.NetWorthEndDate}" />
            </Grid>
        </ui:Card>
    </Grid>
</Page>
