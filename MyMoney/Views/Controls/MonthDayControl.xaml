<UserControl
    x:Class="MyMoney.Views.Controls.MonthDayControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MyMoney.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance local:MonthDayControl,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ui:TextBlock
            Grid.Row="0"
            Grid.Column="0"
            HorizontalAlignment="Center"
            FontSize="{Binding DayFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
            FontWeight="SemiBold"
            Text="{Binding Day, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        <ui:TextBlock
            Grid.Row="1"
            Grid.Column="0"
            HorizontalAlignment="Center"
            Text="{Binding Month, RelativeSource={RelativeSource AncestorType=UserControl}}" />
    </Grid>
</UserControl>
