<UserControl
    x:Class="MyMoney.Views.Controls.BudgetReportControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:MyMoney.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MyMoney.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DataContext="{d:DesignInstance local:BudgetReportControl,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:IsLastItemConverter x:Key="IsLastItemConverter" />
        <converters:IsNegativeConverter x:Key="IsNegativeConverter" />
    </UserControl.Resources>

    <ui:Card
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch">
        <StackPanel>
            <ui:TextBlock
                Margin="0,0,0,24"
                FontTypography="Subtitle"
                Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" />

            <ui:TextBlock
                Margin="0,0,0,8"
                FontWeight="SemiBold"
                Text="Income" />
            <ui:ListView x:Name="IncomeItemsList" ItemsSource="{Binding IncomeItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ui:ListView.Resources>
                    <Style TargetType="{x:Type GridViewColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                    </Style>

                    <Style x:Key="LastItemTextBlockStyle" TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource IsLastItemConverter}">
                                        <!--  current item  -->
                                        <Binding />
                                        <!--  the ItemsSource on the nearest ListView  -->
                                        <Binding ElementName="IncomeItemsList" Path="ItemsSource" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>

                    <Style
                        x:Key="LastItemAndNegativeStyle"
                        BasedOn="{StaticResource LastItemTextBlockStyle}"
                        TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <Binding Converter="{StaticResource IsNegativeConverter}" Path="Remaining" />
                                </DataTrigger.Binding>
                                <Setter Property="Foreground" Value="Red" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:ListView.Resources>
                <ui:ListView.View>
                    <ui:GridView>
                        <GridViewColumn Width="{Binding CategoryColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" Header="Category">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource LastItemTextBlockStyle}" Text="{Binding Category}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="{Binding BudgetedColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" Header="Budgeted">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource LastItemTextBlockStyle}" Text="{Binding Budgeted}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="{Binding ActualColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" Header="Actual">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource LastItemTextBlockStyle}" Text="{Binding Actual}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="{Binding RemainingColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" Header="Remaining">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource LastItemAndNegativeStyle}" Text="{Binding Remaining}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </ui:GridView>
                </ui:ListView.View>
            </ui:ListView>

            <ui:TextBlock
                Margin="0,16,0,8"
                FontWeight="SemiBold"
                Text="Savings" />
            <ui:ListView ItemsSource="{Binding SavingsItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ui:ListView.Resources>
                    <Style TargetType="{x:Type GridViewColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                    </Style>
                </ui:ListView.Resources>
                <ui:ListView.View>
                    <ui:GridView>
                        <GridViewColumn
                            Width="{Binding CategoryColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DisplayMemberBinding="{Binding Category}"
                            Header="Category" />
                        <GridViewColumn
                            Width="{Binding BudgetedColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DisplayMemberBinding="{Binding Saved}"
                            Header="Saved" />
                        <GridViewColumn
                            Width="{Binding ActualColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DisplayMemberBinding="{Binding Spent}"
                            Header="Spent" />
                        <GridViewColumn
                            Width="{Binding RemainingColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            DisplayMemberBinding="{Binding Balance}"
                            Header="Balance" />
                    </ui:GridView>
                </ui:ListView.View>
            </ui:ListView>

            <ui:TextBlock
                Margin="0,16,0,8"
                FontWeight="SemiBold"
                Text="Expenses" />
            <ui:ListView x:Name="ExpenseItemsList" ItemsSource="{Binding GroupedExpenseItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ListView.Resources>
                    <Style TargetType="{x:Type GridViewColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                    </Style>

                    <Style x:Key="LastItemTextBlockStyle" TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource IsLastItemConverter}">
                                        <!--  current item  -->
                                        <Binding />
                                        <!--  the ItemsSource on the nearest ListView  -->
                                        <Binding ElementName="ExpenseItemsList" Path="ItemsSource" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>

                    <Style
                        x:Key="LastItemAndNegativeStyle"
                        BasedOn="{StaticResource LastItemTextBlockStyle}"
                        TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <Binding Converter="{StaticResource IsNegativeConverter}" Path="Remaining" />
                                </DataTrigger.Binding>
                                <Setter Property="Foreground" Value="Red" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Resources>
                <ui:ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <ui:TextBlock
                                    Margin="4,0,4,0"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AccentTextFillColorTertiaryBrush}"
                                    Text="{Binding Name}" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ui:ListView.GroupStyle>
                <ui:ListView.View>
                    <ui:GridView>
                        <GridViewColumn Width="{Binding CategoryColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" Header="Category">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource LastItemTextBlockStyle}" Text="{Binding Category}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="{Binding BudgetedColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" Header="Budgeted">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource LastItemTextBlockStyle}" Text="{Binding Budgeted}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="{Binding ActualColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" Header="Actual">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource LastItemTextBlockStyle}" Text="{Binding Actual}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="{Binding RemainingColumnWidth, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" Header="Remaining">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource LastItemAndNegativeStyle}" Text="{Binding Remaining}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </ui:GridView>
                </ui:ListView.View>
            </ui:ListView>

            <!--  Budget report totals  -->
            <Border
                Margin="0,16,0,0"
                BorderBrush="#828790"
                BorderThickness="1">
                <Grid Margin="12,8,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding CategoryColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <ColumnDefinition Width="{Binding BudgetedColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <ColumnDefinition Width="{Binding ActualColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <ColumnDefinition Width="{Binding RemainingColumnWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBlock
                        Grid.Column="0"
                        FontTypography="BodyStrong"
                        FontWeight="Bold">
                        Remaining
                    </ui:TextBlock>
                    <TextBlock
                        x:Name="ReportTotalTextBlock"
                        Grid.Column="3"
                        FontSize="14"
                        FontWeight="Bold"
                        Text="{Binding ReportTotal, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Value="True">
                                        <DataTrigger.Binding>
                                            <Binding
                                                Converter="{StaticResource IsNegativeConverter}"
                                                Path="ReportTotal"
                                                RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                        </DataTrigger.Binding>
                                        <Setter Property="Foreground" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </StackPanel>
    </ui:Card>
</UserControl>
