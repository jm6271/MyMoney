<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MyMoney.Views.Controls"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Views/Controls/MonthPicker/MonthPickerButtonStyle.xaml"/>
    </ResourceDictionary.MergedDictionaries>
        
        
    <local:MonthYearConverter x:Key="MonthYearConverter" />

    <Style TargetType="{x:Type local:MonthPicker}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:MonthPicker}">
                    <Grid>
                        <ToggleButton x:Name="PART_ToggleButton" Style="{StaticResource MonthPickerToggleButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Text="{Binding SelectedMonth,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Converter={StaticResource MonthYearConverter},
                                              ConverterParameter='MMMM yyyy'}"
                                              FontTypography="Subtitle"/>
                                <ui:SymbolIcon Symbol="CaretDown24" Grid.Column="1" Margin="8,0,0,0"/>
                            </Grid>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               StaysOpen="False"
                               PlacementTarget="{Binding ElementName=PART_ToggleButton}"
                               IsOpen="{Binding IsChecked, ElementName=PART_ToggleButton}"
                               MaxWidth="{TemplateBinding PopupMaxWidth}"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                                    BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                    BorderThickness="1"
                                    Margin="12"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PART_PrevButton"
                                            Grid.Column="0"
                                            Content="&#x25C0;"
                                            VerticalAlignment="Center" />
                                    <ScrollViewer x:Name="PART_ScrollViewer"
                                                  Grid.Column="1"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Tiles, RelativeSource={RelativeSource TemplatedParent}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{x:Null}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Padding="0"
                                                            Cursor="Hand">
                                                        <local:MonthTile Month="{Binding Month}"
                                                                         IsSelected="{Binding IsSelected}"
                                                                         IsCurrentMonth="{Binding IsCurrentMonth}"
                                                                         AccentColor="{Binding AccentColor}"
                                                                         TileWidth="{Binding TileWidth}"
                                                                         TileHeight="{Binding TileHeight}" />
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Button x:Name="PART_NextButton"
                                            Grid.Column="2"
                                            Content="&#x25B6;"
                                            VerticalAlignment="Center" />
                                </Grid>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Direction="270" Opacity="0.135" ShadowDepth="5"
                                                      Color="#202020"/>
                                </Border.Effect>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:MonthTile}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:MonthTile}">
                    <Border x:Name="PART_Border"
                            Width="{TemplateBinding TileWidth}"
                            Height="{TemplateBinding TileHeight}"
                            BorderThickness="2"
                            BorderBrush="Transparent"
                            Background="Transparent">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                      Path=Month,
                                                      Converter={StaticResource MonthYearConverter},
                                                      ConverterParameter=MMM}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                      Path=Month,
                                                      Converter={StaticResource MonthYearConverter},
                                                      ConverterParameter=yyyy}"
                                       FontSize="11"
                                       FontWeight="Normal"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="PART_Border" Property="Background"
                                    Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=AccentColor}" />
                        </Trigger>
                        <Trigger Property="IsCurrentMonth" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush"
                                    Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=AccentColor}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>