{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build and Launch MyMoney",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/MyMoney/bin/Debug/net10.0-windows/MyMoney.exe",
            "args": [],
            "cwd": "${workspaceFolder}/MyMoney/bin/Debug/net10.0-windows",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": ""
            },
            "env": {
                "DOTNET_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "justMyCode": true
        },
        {
            "name": "Launch MyMoney (No Build)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/MyMoney/bin/Debug/net10.0-windows/MyMoney.exe",
            "args": [],
            "cwd": "${workspaceFolder}/MyMoney/bin/Debug/net10.0-windows",
            "stopAtEntry": false,
            "env": {
                "DOTNET_ENVIRONMENT": "Development"
            },
            "justMyCode": true
        }
    ]
}